# HTTP port the Streamlit app listens on
STREAMLIT_SERVER_PORT=8501

# Backend service base URLs.
# In Docker (docker-compose) use the service hostnames below.
# For local development (services running on localhost), copy this file to
# .env and change the hostnames to localhost, e.g.:
#   TREASURY_URL=http://localhost:8080
# Or use:  make run-local
TREASURY_URL=http://treasury-orchestration:8080
LIQUIDITY_URL=http://liquidity-routing:8080
FX_HEDGING_URL=http://fx-hedging:8080
LEDGER_URL=http://ledger-accounting:8080
RECONCILIATION_URL=http://reconciliation:8080
WALLET_URL=http://wallet-management:8080
PAYMENT_URL=http://payment-orchestration:8080
MPC_URL=http://mpc-signing-service:8080
PRICING_URL=http://pricing-quote:8080
NOTIFICATION_URL=http://notification:8080